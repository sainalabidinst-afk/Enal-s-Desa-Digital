generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Village {
  id         String   @id @default(uuid())
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  district   String   @db.VarChar(100)
  headName   String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  citizens     Citizen[]
  familyCards  FamilyCard[]
  letters      Letter[]
  complaints   Complaint[]
  assets       Asset[]

  @@map("villages")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique @db.VarChar(255)
  phone        String?   @unique @db.VarChar(20)
  password     String?   @db.VarChar(255)
  name         String    @db.VarChar(255)
  nik          String?   @unique @db.VarChar(16)
  isActive     Boolean   @default(true)
  roleId       String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role Role @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  submittedLetters Letter[] @relation("LetterSubmitter")
  approvedLetters Letter[] @relation("LetterApprover")
  submittedComplaints Complaint[] @relation("ComplaintSubmitter")
  resolvedComplaints Complaint[] @relation("ComplaintResolver")

  @@index([roleId])
  @@map("users")
}

model FamilyCard {
  id        String   @id @default(uuid())
  nkk       String   @unique @db.VarChar(16)
  headName  String   @db.VarChar(255)
  address   String   @db.Text
  rt        String   @db.VarChar(3)
  rw        String   @db.VarChar(3)
  villageId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  village  Village?   @relation(fields: [villageId], references: [id])
  citizens Citizen[]

  @@index([villageId])
  @@map("family_cards")
}

model Citizen {
  id           String    @id @default(uuid())
  villageId    String
  familyCardId String?
  nik          String    @unique @db.VarChar(16)
  name         String    @db.VarChar(255)
  dateOfBirth  DateTime  @db.Date
  gender       Gender
  address      String    @db.Text
  rt           String    @db.VarChar(3)
  rw           String    @db.VarChar(3)
  religion     String    @db.VarChar(50)
  isAlive      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  village   Village?    @relation(fields: [villageId], references: [id])
  familyCard FamilyCard? @relation(fields: [familyCardId], references: [id])
  letters Letter[]

  @@index([nik])
  @@map("citizens")
}

model LetterType {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(50)
  name           String   @db.VarChar(255)
  requiresApproval Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  letters Letter[]

  @@map("letter_types")
}

model Letter {
  id           String       @id @default(uuid())
  villageId    String
  letterNumber String       @unique @db.VarChar(50)
  citizenId    String
  letterTypeId String
  subject      String       @db.VarChar(255)
  content      String?      @db.Text
  status       LetterStatus @default(PENDING)
  pdfUrl       String?      @db.VarChar(255)
  submittedBy  String
  approvedBy   String?
  signedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  village   Village?  @relation(fields: [villageId], references: [id])
  citizen    Citizen    @relation(fields: [citizenId], references: [id])
  letterType LetterType @relation(fields: [letterTypeId], references: [id])
  submitter  User       @relation("LetterSubmitter", fields: [submittedBy], references: [id])
  approver   User?      @relation("LetterApprover", fields: [approvedBy], references: [id])

  @@index([villageId])
  @@index([citizenId])
  @@index([letterTypeId])
  @@map("letters")
}

model Complaint {
  id             String          @id @default(uuid())
  villageId      String
  citizenId      String
  trackingNumber String          @unique @db.VarChar(50)
  category       ComplaintCategory
  subject        String          @db.VarChar(255)
  description    String          @db.Text
  status         ComplaintStatus @default(PENDING)
  submittedBy    String
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  citizen   Citizen? @relation(fields: [citizenId], references: [id])
  submitter User     @relation("ComplaintSubmitter", fields: [submittedBy], references: [id])
  resolver  User?    @relation("ComplaintResolver", fields: [resolvedBy], references: [id])

  @@index([villageId])
  @@map("complaints")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   @db.VarChar(50)
  resource  String   @db.VarChar(100)
  resourceId String?
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Asset {
  id        String   @id @default(uuid())
  villageId String
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  category  String   @db.VarChar(100)
  condition String   @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([villageId])
  @@map("assets")
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum LetterStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  SIGNED
  CANCELLED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum ComplaintCategory {
  INFRASTRUCTURE
  SECURITY
  SANITATION
  WATER
  ELECTRICITY
  HEALTH
  EDUCATION
  SOCIAL
  ENVIRONMENT
  TRAFFIC
  PUBLIC_FACILITY
  OTHER
}