  caseReport CaseReport @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_timeline")
}

model MissingPerson {
  id            String   @id @default(uuidv7())
  villageId     String
  policeStationId String?
  name          String   @db.VarChar(255)
  photo         String?  @db.VarChar(255)
  gender        Gender
