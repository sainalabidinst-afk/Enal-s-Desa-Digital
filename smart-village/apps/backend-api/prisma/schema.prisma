generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Village {
  id         String   @id @default(uuid())
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  district   String   @db.VarChar(100)
  headName   String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@map("villages")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique @db.VarChar(255)
  phone        String?   @unique @db.VarChar(20)
  password     String?   @db.VarChar(255)
  name         String    @db.VarChar(255)
  nik          String?   @unique @db.VarChar(16)
  isActive     Boolean   @default(true)
  roleId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role Role @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@map("users")
}

model FamilyCard {
  id        String   @id @default(uuid())
  nkk       String   @unique @db.VarChar(16)
  headName  String   @db.VarChar(255)
  address   String   @db.Text
  rt        String   @db.VarChar(3)
  rw        String   @db.VarChar(3)
  villageId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([villageId])
  @@map("family_cards")
}

model Citizen {
  id          String   @id @default(uuid())
  villageId   String
  nik         String   @unique @db.VarChar(16)
  name        String   @db.VarChar(255)
  dateOfBirth DateTime @db.Date
  gender      Gender
  address     String   @db.Text
  rt          String   @db.VarChar(3)
  rw          String   @db.VarChar(3)
  religion    String   @db.VarChar(50)
  isAlive     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([nik])
  @@map("citizens")
}

model LetterType {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(50)
  name           String   @db.VarChar(255)
  requiresApproval Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model Letter {
  id           String      @id @default(uuid())
  villageId    String
  letterNumber String      @unique @db.VarChar(50)
  citizenId    String
  letterTypeId String
  subject      String      @db.VarChar(255)
  content      String?     @db.Text
  status       LetterStatus @default(PENDING)
  pdfUrl       String?     @db.VarChar(255)
  submittedBy  String
  approvedBy   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
}

model Complaint {
  id             String          @id @default(uuid())
  villageId      String
  trackingNumber String          @unique @db.VarChar(50)
  category       ComplaintCategory
  subject        String          @db.VarChar(255)
  description    String          @db.Text
  status         ComplaintStatus @default(PENDING)
  submittedBy    String
  resolvedBy     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
}

model Asset {
  id        String   @id @default(uuid())
  villageId String
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  category  String   @db.VarChar(100)
  condition String   @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([villageId])
  @@map("assets")
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum LetterStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  SIGNED
  CANCELLED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum ComplaintCategory {
  INFRASTRUCTURE
  SECURITY
  SANITATION
  WATER
  ELECTRICITY
  HEALTH
  EDUCATION
  SOCIAL
  ENVIRONMENT
  TRAFFIC
  PUBLIC_FACILITY
  OTHER
}