generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["uuidV7"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE: TENANT (Multi-Tenant Root)
// ============================================================

model Village {
  id         String   @id @default(uuidv7())
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  district   String   @db.VarChar(100)
  city       String   @db.VarChar(100)
  province   String   @db.VarChar(100)
  postalCode String?  @db.VarChar(5)
  latitude   Decimal? @db.Decimal(10, 8)
  longitude  Decimal? @db.Decimal(11, 8)
  headName   String?  @db.VarChar(255)
  headPhone  String?  @db.VarChar(20)
  headEmail  String?  @db.VarChar(255)
  address    String?  @db.Text
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  deletedBy  String?

  citizens       Citizen[]
  familyCards    FamilyCard[]
  letters        Letter[]
  complaints     Complaint[]
  assets         Asset[]
  projects       Project[]
  users          User[]
  featureFlags   FeatureFlag[]
  villageHall    VillageHallBooking[]
  attendance     Attendance[]
  umkms          UMKM[]
  farmerGroups   FarmerGroup[]
  healthPosts    HealthPost[]
  socialAids     SocialAid[]
  policeStations PoliceStation[]
  patrols        Patrol[]
  caseReports    CaseReport[]
  missingPersons MissingPerson[]
  panicButtons   PanicButton[]
  gisLayers      GISLayer[]
  cctvDevices    CCTVDevice[]
  budgets        VillageBudget[]
  budgetItems    BudgetItem[]
  financialTxns  FinancialTransaction[]
  projectProgress ProjectProgress[]
  umkmProducts   UMKMProduct[]
  agriculturalPlots AgriculturalPlot[]
  toddlerRecords ToddlerRecord[]
  aidDistributions AidDistribution[]
  bookings       VillageHallBooking[]

  @@index([code])
  @@index([district, city])
  @@map("villages")
}

// ============================================================
// CORE: AUTH & RBAC
// ============================================================

model Role {
  id          String   @id @default(uuidv7())
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.Text
  level       Int      @default(0) // Hierarchy level: 100=SUPER_ADMIN, 10=WARGA
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuidv7())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@index([resource])
  @@index([slug])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuidv7())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id            String    @id @default(uuidv7())
  email         String?   @unique @db.VarChar(255)
  phone         String?   @unique @db.VarChar(20)
  password      String?   @db.VarChar(255)
  name          String    @db.VarChar(255)
  nik           String?   @unique @db.VarChar(16)
  photo         String?   @db.VarChar(255)
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  lastLoginAt   DateTime?
  lastLoginIp   String?   @db.VarChar(45)
  roleId        String
  villageId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  deletedBy     String?

  role          Role              @relation(fields: [roleId], references: [id])
  village       Village?          @relation(fields: [villageId], references: [id])
  refreshTokens RefreshToken[]
  notifications Notification[]
  auditLogs     AuditLog[]
  letters       Letter[]          @relation("LetterSubmittedBy")
  approvedLetters Letter[]        @relation("LetterApprovedBy")
  complaints    Complaint[]       @relation("ComplaintSubmittedBy")
  resolvedComplaints Complaint[]  @relation("ComplaintResolvedBy")
  patrols       Patrol[]
  attendance    Attendance[]
  caseReports   CaseReport[]      @relation("CaseAssignedTo")
  panicResponses PanicButton[]    @relation("PanicRespondedBy")
  bookings      VillageHallBooking[]
  files         File[]

  @@index([villageId])
  @@index([roleId])
  @@index([nik])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuidv7())
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================
// CORE: FEATURE FLAGS
// ============================================================

model FeatureFlag {
  id        String   @id @default(uuidv7())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  isEnabled Boolean  @default(false)
  villageId String?  // null = global, specific = per village
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  village Village? @relation(fields: [villageId], references: [id])

  @@index([code, villageId])
  @@map("feature_flags")
}

// ============================================================
// CORE: SYSTEM SETTINGS
// ============================================================

model SystemSetting {
  id        String   @id @default(uuidv7())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  type      String   @default("string") @db.VarChar(20) // string, number, boolean, json
  isPublic  Boolean  @default(false)
  villageId String?  // null = global
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key, villageId])
  @@map("system_settings")
}

// ============================================================
// CORE: FILE STORAGE (Centralized)
// ============================================================

model File {
  id           String   @id @default(uuidv7())
  filename     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  mimeType     String   @db.VarChar(100)
  size         Int
  url          String   @db.VarChar(500)
  path         String?  @db.VarChar(500)
  folder       String?  @db.VarChar(100)
  uploadedBy   String
  villageId    String?
  letterId     String?
  complaintId  String?
  assetId      String?
  projectId    String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  deletedBy    String?

  uploader User?   @relation(fields: [uploadedBy], references: [id])
  village  Village? @relation(fields: [villageId], references: [id])

  @@index([uploadedBy])
  @@index([villageId])
  @@index([folder])
  @@map("files")
}

// ============================================================
// CORE: AUDIT TRAIL
// ============================================================

model AuditLog {
  id          String   @id @default(uuidv7())
  userId      String
  action      String   @db.VarChar(50)   // CREATE, UPDATE, DELETE, LOGIN, etc
  resource    String   @db.VarChar(50)   // citizen, letter, complaint, etc
  resourceId  String?  @db.VarChar(50)
  description String?  @db.Text
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  oldValue    Json?
  newValue    Json?
  villageId   String?
  createdAt   DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  village Village? @relation(fields: [villageId], references: [id])

  @@index([userId])
  @@index([resource])
  @@index([resourceId])
  @@index([villageId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// CORE: NOTIFICATION
// ============================================================

model Notification {
  id        String   @id @default(uuidv7())
  userId    String
  title     String   @db.VarChar(255)
  body      String   @db.Text
  type      String   @db.VarChar(50)   // INFO, WARNING, APPROVAL, SYSTEM
  channel   String   @default("IN_APP") @db.VarChar(20) // IN_APP, EMAIL, WHATSAPP, PUSH
  data      Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  deletedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@map("notifications")
}

model NotificationTemplate {
  id      String @id @default(uuidv7())
  code    String @unique @db.VarChar(50)
  title   String @db.VarChar(255)
  body    String @db.Text
  channel String @db.VarChar(20) // EMAIL, WHATSAPP, PUSH, IN_APP
  variables String @db.Text // JSON array of variable names
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

// ============================================================
// CORE: WORKFLOW ENGINE
// ============================================================

model WorkflowDefinition {
  id          String   @id @default(uuidv7())
  code        String   @unique @db.VarChar(50) // SURAT_DOMISILI, SURAT_SKCK, etc
  name        String   @db.VarChar(255)
  description String?  @db.Text
  resource    String   @db.VarChar(50) // letter, complaint, booking
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  stages WorkflowStage[]

  @@map("workflow_definitions")
}

model WorkflowStage {
  id              String   @id @default(uuidv7())
  workflowId      String
  sequence        Int      // 1, 2, 3...
  name            String   @db.VarChar(100) // RT, RW, DESA, POLSEK
  roleSlug        String   @db.VarChar(50)  // Which role approves
  action          String   @default("APPROVE") @db.VarChar(20) // APPROVE, REJECT, FORWARD
  isFinal         Boolean  @default(false)
  autoApprove     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([roleSlug])
  @@map("workflow_stages")
}

model WorkflowInstance {
  id              String   @id @default(uuidv7())
  workflowId      String
  resourceId      String   @db.VarChar(50) // letter_id, complaint_id
  currentStage    Int      @default(1)
  status          String   @default("IN_PROGRESS") @db.VarChar(20) // IN_PROGRESS, APPROVED, REJECTED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id])
  history  WorkflowHistory[]

  @@index([workflowId])
  @@index([resourceId])
  @@index([status])
  @@map("workflow_instances")
}

model WorkflowHistory {
  id         String   @id @default(uuidv7())
  instanceId String
  stageSeq   Int
  action     String   @db.VarChar(20) // APPROVE, REJECT, FORWARD
  notes      String?  @db.Text
  userId     String
  userName   String   @db.VarChar(255)
  userRole   String   @db.VarChar(50)
  createdAt  DateTime @default(now())

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@map("workflow_history")
}

// ============================================================
// MODULE: CITIZEN MANAGEMENT
// ============================================================

model FamilyCard {
  id        String   @id @default(uuidv7())
  nkk       String   @unique @db.VarChar(16)
  headName  String   @db.VarChar(255)
  address   String   @db.Text
  rt        String   @db.VarChar(3)
  rw        String   @db.VarChar(3)
  hamlet    String?  @db.VarChar(100) // Dusun
  villageId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  deletedBy String?

  village  Village   @relation(fields: [villageId], references: [id])
  citizens Citizen[]

  @@index([nkk])
  @@index([villageId])
  @@map("family_cards")
}

model Citizen {
  id              String    @id @default(uuidv7())
  villageId       String
  nik             String    @unique @db.VarChar(16)
  name            String    @db.VarChar(255)
  placeOfBirth    String    @db.VarChar(100)
  dateOfBirth     DateTime  @db.Date
  gender          Gender
  bloodType       String?   @db.VarChar(3)
  address         String    @db.Text
  rt              String    @db.VarChar(3)
  rw              String    @db.VarChar(3)
  hamlet          String?   @db.VarChar(100) // Dusun
  district        String    @db.VarChar(100)
  city            String    @db.VarChar(100)
  province        String    @db.VarChar(100)
  postalCode      String?   @db.VarChar(5)
  religion        String    @db.VarChar(50)
  maritalStatus   String    @db.VarChar(50)
  occupation      String?   @db.VarChar(100)
  education       String?   @db.VarChar(50)
  nationality     String    @default("WNI") @db.VarChar(10)
  fatherName      String?   @db.VarChar(255)
  motherName      String?   @db.VarChar(255)
  spouseName      String?   @db.VarChar(255)
  familyStatus    String    @default("KEPALA_KELUARGA") @db.VarChar(50)
  familyCardId    String?
  photo           String?   @db.VarChar(255)
  qrCode          String?   @db.VarChar(255)
  userId          String?   @unique
  isAlive         Boolean   @default(true)
  deathDate       DateTime? @db.Date
  deathCertificate String?  @db.VarChar(255)
  disability      String?   @db.VarChar(50) // TIDAK_ADA, FISIK, MENTAL, GANDA
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedBy       String?

  village   Village     @relation(fields: [villageId], references: [id])
  familyCard FamilyCard? @relation(fields: [familyCardId], references: [id])
  letters   Letter[]
  mutations ResidentMutation[]

  @@index([nik])
  @@index([name])
  @@index([villageId])
  @@index([villageId, nik])
  @@index([villageId, gender])
  @@index([villageId, isAlive])
  @@map("citizens")
}

model ResidentMutation {
  id          String   @id @default(uuidv7())
  citizenId   String
  type        String   @db.VarChar(20) // BIRTH, DEATH, MOVE_IN, MOVE_OUT, ARRIVAL
  date        DateTime @db.Date
  description String?  @db.Text
  fromVillage String?  @db.VarChar(100)
  toVillage   String?  @db.VarChar(100)
  documentUrl String?  @db.VarChar(255)
  recordedBy  String
  villageId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  citizen Citizen @relation(fields: [citizenId], references: [id])
  village Village @relation(fields: [villageId], references: [id])

  @@index([citizenId])
  @@index([villageId])
  @@index([type])
  @@map("resident_mutations")
}

// ============================================================
// MODULE: DIGITAL LETTER
// ============================================================

model LetterType {
  id               String   @id @default(uuidv7())
  code             String   @unique @db.VarChar(50)
  name             String   @db.VarChar(255)
  description      String?  @db.Text
  template         String?  @db.Text
  requirements     String?  @db.Text
  validityDays     Int?
  isActive         Boolean  @default(true)
  requiresApproval Boolean  @default(true)
  workflowCode     String?  @db.VarChar(50) // Link to WorkflowDefinition.code
  fee              Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  letters Letter[]

  @@map("letter_types")
}

model Letter {
  id              String      @id @default(uuidv7())
  villageId       String
  letterNumber    String      @unique @db.VarChar(50)
  citizenId       String
  letterTypeId    String
  subject         String      @db.VarChar(255)
  content         String      @db.Text
  status          LetterStatus @default(PENDING)
  priority        String?     @default("NORMAL") @db.VarChar(20)
  validUntil      DateTime?
  signedAt        DateTime?
  signedBy        String?
  signature       String?     @db.VarChar(255) // Digital signature image
  qrCode          String?     @db.VarChar(255) // QR verification code
  pdfUrl          String?     @db.VarChar(255)
  notes           String?     @db.Text
  submittedBy     String
  approvedBy      String?
  workflowId      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  deletedBy       String?

  village    Village    @relation(fields: [villageId], references: [id])
  citizen    Citizen    @relation(fields: [citizenId], references: [id])
  letterType LetterType @relation(fields: [letterTypeId], references: [id])
  submitter  User       @relation("LetterSubmittedBy", fields: [submittedBy], references: [id])
  approver   User?      @relation("LetterApprovedBy", fields: [approvedBy], references: [id])
  history    LetterHistory[]
  files      File[]

  @@index([letterNumber])
  @@index([citizenId])
  @@index([villageId])
  @@index([status])
  @@index([letterTypeId])
  @@index([villageId, status])
  @@map("letters")
}

model LetterHistory {
  id        String   @id @default(uuidv7())
  letterId  String
  action    String   @db.VarChar(50) // SUBMIT, APPROVE, REJECT, SIGN, PRINT, EXPIRED
  status    String   @db.VarChar(50)
  notes     String?  @db.Text
  userId    String
  userName  String   @db.VarChar(255)
  userRole  String   @db.VarChar(50)
  createdAt DateTime @default(now())

  letter Letter @relation(fields: [letterId], references: [id], onDelete: Cascade)

  @@index([letterId])
  @@map("letter_history")
}

// ============================================================
// MODULE: COMPLAINT CENTER
// ============================================================

model Complaint {
  id              String           @id @default(uuidv7())
  villageId       String
  trackingNumber  String           @unique @db.VarChar(50)
  category        ComplaintCategory
  subject         String           @db.VarChar(255)
  description     String           @db.Text
  location        String?          @db.Text
  latitude        Decimal?         @db.Decimal(10, 8)
  longitude       Decimal?         @db.Decimal(11, 8)
  status          ComplaintStatus  @default(PENDING)
  priority        String?          @default("NORMAL") @db.VarChar(20)
  photos          String[]         @default([])
  videos          String[]         @default([])
  assignedTo      String?
  assignedToType  String?          @db.VarChar(50) // DESA, POLSEK, PU, etc
  reporterName    String           @db.VarChar(255)
  reporterPhone   String           @db.VarChar(20)
  reporterEmail   String?          @db.VarChar(255)
  isAnonymous     Boolean          @default(false)
  resolution      String?          @db.Text
  resolvedAt      DateTime?
  resolvedBy      String?
  submittedBy     String
  workflowId      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedBy       String?

  village  Village  @relation(fields: [villageId], references: [id])
  submitter User    @relation("ComplaintSubmittedBy", fields: [submittedBy], references: [id])
  resolver User?    @relation("ComplaintResolvedBy", fields: [resolvedBy], references: [id])
  timeline ComplaintTimeline[]
  files    File[]

  @@index([trackingNumber])
  @@index([villageId])
  @@index([status])
  @@index([category])
  @@index([villageId, status])
  @@map("complaints")
}

model ComplaintTimeline {
  id          String   @id @default(uuidv7())
  complaintId String
  status      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  notes       String?  @db.Text
  userId      String
  userName    String   @db.VarChar(255)
  userRole    String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("complaint_timeline")
}

// ============================================================
// MODULE: ASSET MANAGEMENT
// ============================================================

model Asset {
  id            String   @id @default(uuidv7())
  villageId     String
  code          String   @unique @db.VarChar(50)
  name          String   @db.VarChar(255)
  category      String   @db.VarChar(100) // ELEKTRONIK, KENDARAAN, BANGUNAN, INFRASTRUKTUR, TANAH, dll
  subCategory   String?  @db.VarChar(100)
  condition     String   @db.VarChar(50) // BAIK, RUSAK_RINGAN, RUSAK_BERAT
  purchaseDate  DateTime?
  purchasePrice Decimal? @db.Decimal(12, 2)
  location      String?  @db.VarChar(255)
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  photo         String?  @db.VarChar(255)
  qrCode        String?  @db.VarChar(255)
  assignedTo    String?  @db.VarChar(255)
  notes         String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  deletedBy     String?

  village      Village          @relation(fields: [villageId], references: [id])
  maintenance  AssetMaintenance[]
  files        File[]

  @@index([villageId])
  @@index([code])
  @@index([category])
  @@index([villageId, category])
  @@map("assets")
}

model AssetMaintenance {
  id          String   @id @default(uuidv7())
  assetId     String
  date        DateTime @db.Date
  type        String   @db.VarChar(50) // ROUTINE, REPAIR, OVERHAUL
  description String   @db.Text
  cost        Decimal? @db.Decimal(12, 2)
  technician  String?  @db.VarChar(255)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([date])
  @@map("asset_maintenance")
}

// ============================================================
// MODULE: PROJECT MANAGEMENT
// ============================================================

model Project {
  id          String   @id @default(uuidv7())
  villageId   String
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(255)
  category    String   @db.VarChar(100) // JALAN, DRAINASE, JEMBATAN, IRIGASI, SEKOLAH, POSYANDU
  description String?  @db.Text
  budget      Decimal? @db.Decimal(15, 2)
  startDate   DateTime @db.Date
  endDate     DateTime? @db.Date
  status      String   @default("PLANNING") @db.VarChar(20) // PLANNING, IN_PROGRESS, COMPLETED, CANCELLED
  location    String?  @db.VarChar(255)
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  photoBefore String?  @db.VarChar(255)
  photoAfter  String?  @db.VarChar(255)
  contractor  String?  @db.VarChar(255)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  village  Village           @relation(fields: [villageId], references: [id])
  progress ProjectProgress[]
  files    File[]

  @@index([villageId])
  @@index([code])
  @@index([status])
  @@map("projects")
}

model ProjectProgress {
  id          String   @id @default(uuidv7())
  projectId   String
  percentage  Int      @default(0) // 0, 25, 50, 75, 100
  description String?  @db.Text
  photo       String?  @db.VarChar(255)
  reportedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
