# ============================================================
# Smart Village API - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database (PostgreSQL 17 + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_village?schema=public

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-minimum-32-characters!!
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (Cache & Queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (File Storage - S3 Compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-village
MINIO_USE_SSL=false

# SMTP Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@smartvillage.go.id

# Firebase Cloud Messaging (Optional - Mobile Push)
FCM_SERVER_KEY=your-fcm-server-key

# WhatsApp Gateway (Optional)
WHATSAPP_API_URL=https://api.fonnte.com
WHATSAPP_API_KEY=your-whatsapp-api-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Max File Upload (10MB)
MAX_FILE_SIZE=10485760